# ---------------------- | SQLite Configuration | ----------------------
SQLALCHEMY_DATABASE_URI=sqlite:///zencrypt.db
DATABASE_PATH=zencrypt.db

# ---------------------- | Flask Configuration | ----------------------
FLASK_ENV=development
FLASK_APP=webapp.py
# Production on Server:
# FLASK_ENV=production
# FLASK_DEBUG=0

# ---------------------- | JWT and User Sessions | --------------------
# Use a strong random value for production (at least 32 bytes of entropy)
SECRET_KEY=<your_secret_key_or_secret_file_path>
JWT_SECRET_KEY=<your_jwt_secret_key>

# ---------------------- | Paths For Keys | ---------------------------
KEY_FILE_PATH=<optional_path_to_private_key_file>
KEY_FILE=<optional_private_key_filename>

# ---------------------- | Python Version | ---------------------------
PYTHON_VERSION=3.11.11

# Solana Pay and NFT gating configuration
ZENCRYPT_TOKEN_MINT=<your_token_mint>
ZENCRYPT_MIN_TOKEN_BALANCE=1
RPC_URL=<your_rpc_url>
HELIUS_API_KEY=<your_helius_api_key>
MERCHANT_WALLET=<your_wallet_address>
SOLANA_PAY_LABEL=Zencrypt
ZENCRYPT_COLLECTION_MINT=<your_collection_mint>
ZENCRYPT_DAPP_URL=<your_app_url>

# Optional Picket settings
# USE_PICKET=false
# PICKET_API_KEY=<your_picket_key>
# PICKET_PROJECT_ID=<your_project_id>
# PICKET_ENVIRONMENT=production
# PICKET_API_URL=https://api.picket.gg
# PICKET_CACHE_TTL=120
